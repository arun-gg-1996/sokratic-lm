# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment variables
.env
.env.*
!.env.example

# Data — raw PDFs and large processed files (too big for git)
data/raw/
data/processed/
data/indexes/
data/simulations/

# Keep these tracked (curated assets + eval sets)
!data/diagrams/
!data/eval/
!data/artifacts/tool_definitions.json
!data/textbook_structure.json

# Local/generated artifacts (do not push)
data/artifacts/conversations/
data/artifacts/dean_interventions/
data/artifacts/euler_scores/
data/artifacts/final_convo/
data/artifacts/human_convos/
data/artifacts/human_scripts/
data/artifacts/prompts/
data/artifacts/session_prompts/
data/artifacts/local_structural_quality_flags.json
data/artifacts/simulation_analysis_latest2.json
data/artifacts/turn_quality_bad_root_causes.json
data/artifacts/turn_quality_report.json

# Eval-run output dirs (per-conversation JSONs, summaries) — these are
# regenerable from scripts/run_*.py and would bloat the repo. Audit
# markdown files inside are kept (curated writeups about specific runs).
data/artifacts/scaled_convo/
!data/artifacts/scaled_convo/**/*.md
data/artifacts/multi_session/
!data/artifacts/multi_session/**/*.md
data/artifacts/validate_gates/

# One-off diagnostic / comparison dumps
data/artifacts/failed_chunks_diagnostic.json
data/artifacts/proposition_model_comparison.json

# RAPTOR precomputed summaries — large (1MB+), regenerable, belong
# in the HF corpus snapshot, not git
data/artifacts/raptor_section_summaries.jsonl
data/artifacts/raptor_subsection_summaries.jsonl

# Cache smoke test logs are small, durable, paper-relevant — keep tracked
!data/artifacts/cache_smoke/
!data/artifacts/cache_smoke/*.log

# E2E test runs: keep markdown reports tracked (paper / regression
# evidence), drop the heavy per-scenario JSONs to avoid bloat.
data/artifacts/e2e/**/*.json
!data/artifacts/e2e/
!data/artifacts/e2e/**/*.md

# Classifier validation runs: keep markdown reports, drop heavy
# per-classifier raw JSONs.
data/artifacts/classifiers/**/*.json
!data/artifacts/classifiers/
!data/artifacts/classifiers/**/*.md

# Per-student mastery store (private to each user; written at session end)
data/student_state/

# Legacy eval outputs from data/eval/ (only the legacy_compare_* and
# realistic_eval_* time-stamped variants — curated topic banks etc.
# stay tracked).
data/eval/legacy_compare_*.json
data/eval/realistic_eval_*.json

# Claude Code local state (worktrees, plan files, session traces)
.claude/

# Programmatic conversation debug dumps (ephemeral)
programmatic conversations/

# Local handoff bundles / snapshots (too large for repo)
sokratic_handoff_nidhi/
socrates-vector-icon-isolated-transparent-background-socrate-transparency-concept-can-be-used-web-mobile-127338010.webp

# Qdrant local storage
qdrant_storage/
.qdrant_data/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
*.log
!data/artifacts/cache_smoke/*.log
claude-ui.html

# React/FastAPI scaffold local artifacts
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/pnpm-debug.log*
frontend/tsconfig.tsbuildinfo
backend/__pycache__/
backend/**/__pycache__/
