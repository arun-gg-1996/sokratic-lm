# ─────────────────────────────────────────────────────────────────────────────
# Sokratic-OT — environment variables
# Copy this file to `.env` and fill in real values. The repo's .gitignore
# excludes `.env*`, so secrets stay local.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── Required: LLM providers ─────────────────────────────────────────────────
# Anthropic — used by teacher (Haiku), dean (Haiku), evaluator (Haiku),
# and vision flow (Sonnet). Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used ONLY for embeddings (text-embedding-3-large) when (re)building
# the Qdrant index from chunks. Not used at runtime if the index already
# exists. Get one at https://platform.openai.com/api-keys.
OPENAI_API_KEY=sk-...

# ─── Required: domain selection ──────────────────────────────────────────────
# Selects which `config/domains/<domain>.yaml` to merge into config/base.yaml.
# Valid: "ot" (anatomy — default), "physics" (legacy/experimental).
SOKRATIC_DOMAIN=ot

# ─── Required for first-time data pull from HuggingFace ──────────────────────
# Used by `scripts/bootstrap_corpus.py` to download the processed corpus
# (chunks, propositions, BM25 index, topic_index, textbook_structure).
# HF_TOKEN is only needed if the dataset repo is private — for the public
# `arun-ghontale/sokratic-anatomy-corpus` repo it can be left blank.
# HF_USERNAME defaults the repo owner; override if you've forked the dataset.
HF_USERNAME=arun-ghontale
HF_TOKEN=

# ─── Optional: LangSmith tracing (free tier, 5000 traces/month) ──────────────
# Sign up at https://smith.langchain.com — LangGraph picks this up
# automatically once the keys are present (zero code changes).
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=sokratic-ot

# ─── Optional: Qdrant connection ─────────────────────────────────────────────
# Defaults match `scripts/qdrant_up.sh` (Docker-on-localhost). Override only
# if you're pointing at a remote Qdrant cluster.
# QDRANT_HOST=localhost
# QDRANT_HTTP_PORT=6333
# QDRANT_GRPC_PORT=6334
# QDRANT_DATA_DIR=./.qdrant_data

# ─── Optional: frontend → backend wiring ─────────────────────────────────────
# Read by Vite at build time. Default is fine for `pnpm dev` on the same host.
# Override when the FastAPI backend is on a different origin.
# VITE_API_BASE=http://localhost:8000

# ─── Optional: HuggingFace cache (offline mode) ──────────────────────────────
# When set, the cross-encoder won't try to redownload the model. Useful in
# CI / air-gapped runs. The model lives in ~/.cache/huggingface by default.
# TRANSFORMERS_OFFLINE=1
# HF_HOME=~/.cache/huggingface
